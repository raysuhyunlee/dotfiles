# delta: syntax-highlighted diff pager (https://github.com/dandavison/delta)
[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true        # use n / N to jump between diff sections
	line-numbers = true
	# side-by-side = true  # uncomment for two-column diffs

[merge]
	conflictstyle = zdiff3 # clearer conflict markers with common base

[diff]
	colorMoved = default   # distinguish moved lines from add/remove
